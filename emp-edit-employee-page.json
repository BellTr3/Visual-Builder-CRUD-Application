{
  "title": "Edit Employee",
  "description": "Updates single Employee record",
  "variables": {
    "departmentListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "businessObjects/getall_Department",
        "keyAttributes": "id",
        "itemsPath": "items",
        "responseType": "getallDepartmentResponse",
        "uriParameters": {}
      }
    },
    "employee": {
      "type": "getEmployeeResponse"
    },
    "employeeETag": {
      "type": "string"
    },
    "employeeId": {
      "type": "string",
      "required": true,
      "input": "fromUrl"
    },
    "fetchedEmployee": {
      "type": "getEmployeeResponse"
    },
    "saveEmployeeChainInProgress": {
      "type": "boolean",
      "defaultValue": false
    }
  },
  "metadata": {},
  "types": {
    "@decorators.getallDepartmentResponse": {
      "endpoint": "getall_Department",
      "service": "businessObjects",
      "path": "response"
    },
    "@decorators.getEmployeeResponse": {
      "endpoint": "get_Employee",
      "service": "businessObjects",
      "path": "response"
    },
    "getallDepartmentResponse": {
      "items": [
        {
          "id": "number",
          "name": "string"
        }
      ]
    },
    "getEmployeeResponse": {
      "country": "string",
      "department": "number",
      "email": "string",
      "name": "string",
      "salary": "number"
    }
  },
  "eventListeners": {
    "backButtonClicked": {
      "chains": [
        {
          "chain": "goBackChain"
        }
      ]
    },
    "saveButtonClicked": {
      "chains": [
        {
          "chain": "saveEmployeeChain"
        }
      ]
    },
    "vbEnter": {
      "chains": [
        {
          "chain": "loadEmployeeChain"
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-form-layout": {
        "path": "ojs/ojformlayout"
      },
      "oj-input-number": {
        "path": "ojs/ojinputnumber"
      },
      "oj-input-text": {
        "path": "ojs/ojinputtext"
      },
      "oj-select-single": {
        "path": "ojs/ojselectsingle"
      },
      "oj-validation-group": {
        "path": "ojs/ojvalidationgroup"
      }
   },
    "modules": {
      "ojConverterNumber": {
        "path": "ojs/ojconverter-number"
      },
      "ojValidationNumber": {
        "path": "ojs/ojvalidation-number"
      }
    }
  }
}
{
  "title": "List of Employees",
  "description": "",
  "variables": {
    "employeeListSDP": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "businessObjects/getall_Employee",
        "keyAttributes": "id",
        "itemsPath": "items",
        "responseType": "getallEmployeeResponse"
      }
    },
    "employeeListSDP2": {
      "type": "vb/ServiceDataProvider",
      "defaultValue": {
        "endpoint": "businessObjects/getall_Employee",
        "keyAttributes": "id",
        "itemsPath": "items",
        "responseType": "getallEmployeeResponse2"
      }
    },
    "oj_table_959444773_1SelectedId": {
      "type": "string",
      "defaultValue": ""
    }
  },
  "metadata": {},
  "types": {
    "@decorators.getallEmployeeResponse": {
      "endpoint": "getall_Employee",
      "service": "businessObjects",
      "path": "response"
    },
    "@decorators.getallEmployeeResponse2": {
      "endpoint": "getall_Employee",
      "service": "businessObjects",
      "path": "response"
    },
    "getallEmployeeResponse": {
      "items": [
        {
          "email": "string",
          "id": "number",
          "job": "string",
          "name": "string",
          "salary": "number"
        }
      ]
    },
    "getallEmployeeResponse2": {
      "items": [
        {
          "id": "number",
          "name": "string",
          "salary": "number"
        }
      ]
    }
  },
  "eventListeners": {
    "createEmployeeButtonClicked": {
      "chains": [
        {
          "chain": "navigateToCreateEmployeeChain"
        }
      ]
    },
    "deleteEmployeeButtonClicked": {
      "chains": [
        {
          "chain": "deleteEmployeeChain",
          "parameters": {
            "employeeId": "[[ $variables.oj_table_959444773_1SelectedId ]]"
          }
        }
      ]
    },
    "editEmployeeButtonClicked": {
      "chains": [
        {
          "chain": "navigateToEditEmployeeChain",
          "parameters": {
            "employeeId": "[[ $variables.oj_table_959444773_1SelectedId ]]"
          }
        }
      ]
    },
    "oj_table_959444773_1SelectionChanged": {
      "chains": [
        {
          "chain": "ojTable9594447731ChangeSelectionChain",
          "parameters": {
            "employeeId": "[[ $event.detail.value.key || '' ]]"
          }
        }
      ]
    }
  },
  "imports": {
    "components": {
      "oj-button": {
        "path": "ojs/ojbutton"
      },
      "oj-chart": {
        "path": "ojs/ojchart"
      },
      "oj-chart-item": {
        "path": "ojs/ojchart"
      },
      "oj-input-number": {
        "path": "ojs/ojinputnumber"
      },
      "oj-table": {
        "path": "ojs/ojtable"
      },
      "oj-toolbar": {
        "path": "ojs/ojtoolbar"
      }
   },
    "modules": {
      "ojConverterNumber": {
        "path": "ojs/ojconverter-number"
      },
      "ojValidationNumber": {
        "path": "ojs/ojvalidation-number"
      }
    }
  }
}